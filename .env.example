# Solana token gate
# New names. ENTRAIN_MINT is still accepted as a backward-compatible alias.
TOKEN_TICKER=WAVES
TOKEN_DISPLAY_NAME=$WAVES
TOKEN_CHAIN=solana
TOKEN_MINT=3Ae5SuwRUsQPuJD8LJAPgpDtATCnpSndt3ikwKHQpump
SOLANA_RPC=https://api.mainnet-beta.solana.com
SESSION_COOKIE=entrain_session

# Development only: set to 1 to bypass holder checks for local UI work.
ALLOW_DEV_UNLOCK=0

# Admin soundtrack manager. Use a long random value in production.
ADMIN_TOKEN=change-me-locally

# Creator marketplace
# Paid creator tracks use direct SOL transfers to each creator payout wallet.
MARKETPLACE_CURRENCY=SOL
